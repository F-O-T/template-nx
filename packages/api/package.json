{
  "name": "@packages/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --build --emitDeclarationOnly",
    "lint": "oxlint -c ../../tooling/oxc/oxlintrc.packages.json",
    "format": "oxfmt --write src"
  },
  "dependencies": {
    "@orpc/client": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@core/auth": "workspace:*",
    "@core/db": "workspace:*",
    "@core/arcjet": "workspace:*",
    "@core/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tooling/config": "workspace:*",
    "@tooling/test": "workspace:*",
    "typescript": "^5"
  }
}
