{
  "name": "@packages/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "default": "./dist/components/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "default": "./dist/hooks/*.js"
    },
    "./postcss.config": "./postcss.config.mjs"
  },
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --build --emitDeclarationOnly",
    "lint": "oxlint -c ../../tooling/oxc/oxlintrc.packages.json",
    "format": "oxfmt --write src"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "catalog:",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "^3.6.2",
    "sonner": "catalog:",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.4"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@tooling/config": "workspace:*",
    "tailwindcss": "catalog:",
    "typescript": "^5.9.3"
  }
}
