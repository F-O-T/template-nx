{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "sync": {
    "applyChanges": true
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "check-types"
        },
        "build": {
          "targetName": "build:tsc",
          "configName": "tsconfig.json"
        }
      }
    },
    {
      "plugin": "@nx/vite",
      "options": {
        "buildTargetName": "build",
        "devTargetName": "dev",
        "previewTargetName": "serve"
      }
    }
  ],
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json"
    ],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "build:tsc": {
      "dependsOn": ["^build:tsc"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "inputs": ["default", "^default"],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "format": {
      "cache": true
    },
    "check-boundaries": {
      "cache": true
    },
    "dev": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false
    },
    "db:start": {
      "cache": false
    },
    "db:stop": {
      "cache": false
    },
    "db:watch": {
      "cache": false
    },
    "db:down": {
      "cache": false
    }
  }
}
