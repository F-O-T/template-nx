{
  "name": "working-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "core/*",
      "tooling/*",
      "libs/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/node": "^22.13.14",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@orpc/server": "^1.12.2",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.2",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "dev:web": "nx run-many -t dev --projects=@apps/web",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint -- --fix",
    "format": "nx run-many -t format",
    "check": "bun run lint && bun run format",
    "check-boundaries": "bun run tooling/boundary/check-boundaries.ts",
    "db:push": "nx run-many -t db:push --projects=@core/db",
    "db:studio": "nx run-many -t db:studio --projects=@core/db",
    "db:generate": "nx run-many -t db:generate --projects=@core/db",
    "db:migrate": "nx run-many -t db:migrate --projects=@core/db",
    "db:start": "nx run-many -t db:start --projects=@core/db",
    "db:watch": "nx run-many -t db:watch --projects=@core/db",
    "db:stop": "nx run-many -t db:stop --projects=@core/db",
    "db:down": "nx run-many -t db:down --projects=@core/db"
  },
  "dependencies": {
    "@core/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nx/js": "^22.5.4",
    "@nx/vite": "^22.5.4",
    "@tooling/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.0.13",
    "nx": "^21.5.2",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.9"
}
