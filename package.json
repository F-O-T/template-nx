{
  "name": "working-app",
  "private": true,
  "license": "MIT",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "core/*",
      "tooling/*",
      "libs/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/node": "^22.13.14",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@orpc/server": "^1.12.2",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.2",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test:unit && nx run-many -t test:integration",
    "test:affected": "nx affected -t test:unit --base=origin/master --head=HEAD --parallel=3 && nx affected -t test:integration --base=origin/master --head=HEAD --parallel=1",
    "check-types": "nx run-many -t check-types",
    "check-types:affected": "nx affected -t check-types --base=origin/master --head=HEAD --parallel=3",
    "dev:web": "nx run-many -t dev --projects=@apps/web",
    "dev:storybook": "nx storybook @apps/storybook",
    "lint": "nx run-many -t lint",
    "lint:affected": "nx affected -t lint --base=origin/master --head=HEAD --parallel=3",
    "lint:fix": "nx run-many -t lint -- --fix",
    "format": "nx run-many -t format",
    "format:check": "bun run tooling/oxc/check-format.ts --write",
    "check": "bun run lint && bun run format",
    "check-boundaries": "bun run tooling/boundary/check-boundaries.ts",
    "db:push": "nx run-many -t db:push --projects=@core/db",
    "db:studio": "nx run-many -t db:studio --projects=@core/db",
    "db:generate": "nx run-many -t db:generate --projects=@core/db",
    "db:migrate": "nx run-many -t db:migrate --projects=@core/db",
    "db:start": "nx run-many -t db:start --projects=@core/db",
    "db:watch": "nx run-many -t db:watch --projects=@core/db",
    "db:stop": "nx run-many -t db:stop --projects=@core/db",
    "db:down": "nx run-many -t db:down --projects=@core/db"
  },
  "dependencies": {
    "@core/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.15.0",
    "@nx/js": "^22.5.4",
    "@nx/react": "^22.5.4",
    "@nx/storybook": "^22.5.4",
    "@nx/vitest": "^22.5.4",
    "@nx/vite": "^22.5.4",
    "@nx/web": "22.5.4",
    "@storybook/addon-themes": "^10.2.19",
    "@storybook/react-vite": "10.2.19",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@tailwindcss/vite": "^4.2.1",
    "@tooling/config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv-cli": "^11.0.0",
    "lefthook": "^2.0.13",
    "nx": "^21.5.2",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "prettier": "~3.6.2",
    "storybook": "10.2.19",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "bun@1.3.9"
}
